# Convex — after `npx convex dev` or from Convex dashboard → Settings → URL
# IMPORTANT: This URL must be the SAME deployment as in the Convex dashboard where you check the `users` table.
# Example: CONVEX_DEPLOYMENT=dev:fortunate-capybara-474 → NEXT_PUBLIC_CONVEX_URL=https://fortunate-capybara-474.convex.cloud
# Restart `npm run dev` after changing. On Vercel, set the same value in Project → Environment Variables.
NEXT_PUBLIC_CONVEX_URL=
# The Next app uses only NEXT_PUBLIC_CONVEX_URL (not CONVEX_URL) so it always matches the dashboard you intend.
# Optional: Convex CLI may still set CONVEX_URL for `npx convex dev`; keep it the same host as NEXT_PUBLIC_* if both exist.
# CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# Convex → Settings → Environment Variables (server-side only; do NOT prefix with NEXT_PUBLIC_)
# Resend: https://resend.com — create an API key and add the SAME variable name in Convex.
# RESEND_API_KEY=
# Optional "from" address. Until your domain is verified at https://resend.com/domains , Resend only
# delivers to your Resend account email; the app falls back to one admin email + skips user confirmation.
# Use your verified domain address so both the admin copy (joinvibo@gmail.com) and the submitter
# confirmation appear From: businesses@joinvibo.com (or similar).
# RESEND_FROM_EMAIL=Vibo Business <businesses@joinvibo.com>

# Help Center AI — MUST be set in Convex (this file is NOT used by Convex actions).
# 1) Create a key at https://openrouter.ai/keys
# 2) Convex Dashboard → your deployment → Settings → Environment Variables
# 3) Add: OPENROUTER_API_KEY = sk-or-v1-... (exact name; no NEXT_PUBLIC_ prefix)
# 4) Save so Convex redeploys. Vercel / .env.local do NOT supply this; only Convex does.
# CLI (optional): npx convex env set OPENROUTER_API_KEY sk-or-v1-...
# Optional:
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://joinvibo.com
# OPENROUTER_APP_TITLE=Vibo Help Center

# Vercel / CI — Convex → Settings → Deploy key (only for production deploys, not local dev)
# CONVEX_DEPLOY_KEY=

# Newsroom — free key from https://newsapi.org (optional; mock articles used if unset)
# NEWS_API_KEY=

# Blog / Newsroom — auto Arabic when manual Arabic fields are empty (LibreTranslate).
# LIBRETRANSLATE_URL alone is NOT enough for https://libretranslate.com — you MUST set an API key
# (“Get API Key” on https://libretranslate.com/). Restart Next.js after changing env.
# Optional: self-hosted base URL (non-libretranslate.com hosts may allow requests without a key).
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=

# Hero MP4s — pick ONE approach (leave all unset locally if files exist in public/videos/)
#
# A) Full URL per clip in Vercel (paste each “Copy link” from GitHub Release assets):
# NEXT_PUBLIC_VIDEO_VID1=https://github.com/vibobh/vibo-webapp/releases/download/media-v1/vid1.mp4
# NEXT_PUBLIC_VIDEO_VID2=
# NEXT_PUBLIC_VIDEO_VID3=
# NEXT_PUBLIC_VIDEO_VID4=
# NEXT_PUBLIC_VIDEO_VID5=
#
# B) Or one base folder (no trailing slash); filenames vid1.mp4…vid5.mp4 are appended:
# NEXT_PUBLIC_VIDEO_BASE_URL=https://github.com/vibobh/vibo-webapp/releases/download/media-v1

# Blog (Convex required for posts). Set the SAME BLOG_ADMIN_SECRET in Convex Dashboard → Settings → Environment Variables.
# BLOG_SESSION_SECRET — random string (e.g. openssl rand -hex 32) to sign admin cookies
# BLOG_ADMIN_SECRET — random string shared with Convex; never commit real values
# BLOG_ADMIN_EMAIL / BLOG_ADMIN_PASSWORD — sign-in for https://joinvibo.com/mangment
# Optional second editor: BLOG_ADMIN_EMAIL_2 + BLOG_ADMIN_PASSWORD_2 (same pattern up to _10)
# Or one JSON array (single line): BLOG_ADMIN_USERS=[{"email":"a@b.com","password":"..."},{"email":"c@d.com","password":"..."}]
# BLOG_SESSION_SECRET=
# BLOG_ADMIN_SECRET=
# BLOG_ADMIN_EMAIL=
# BLOG_ADMIN_PASSWORD=
# BLOG_ADMIN_EMAIL_2=
# BLOG_ADMIN_PASSWORD_2=
# BLOG_ADMIN_USERS=

# SEO / JSON-LD sameAs (optional). Set real profile URLs for production — used in schema.org Organization + SoftwareApplication.
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/...
# NEXT_PUBLIC_SOCIAL_X=https://x.com/...
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/...
# NEXT_PUBLIC_SOCIAL_TIKTOK=https://www.tiktok.com/@...
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/@...

# Convex — root convex.json deploys `convex_app/` (see convex_app/README.md). Run `npm run convex:dev`
# from the repo root, then use the deployment URL below.
# IMPORTANT: This URL must be the SAME deployment as in the Convex dashboard where you check the `users` table.
# Example: CONVEX_DEPLOYMENT=dev:fortunate-capybara-474 → NEXT_PUBLIC_CONVEX_URL=https://fortunate-capybara-474.convex.cloud
# Restart `npm run dev` after changing. On Vercel, set the same value in Project → Environment Variables.
# Next.js inlines NEXT_PUBLIC_* at build time; do not use EXPO_PUBLIC_* for this repo (Expo mobile only), unless you rely on next.config fallbacks.
NEXT_PUBLIC_CONVEX_URL=
# If unset, next.config.js falls back to EXPO_PUBLIC_CONVEX_URL, then CONVEX_URL (CLI), then SOURCE_CONVEX_URL. Prefer NEXT_PUBLIC_* on Vercel.
# CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
# SOURCE_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# Web auth (JWT for login/signup; Convex validates via JWKS). Set on Vercel for production auth.
# PEM as one line with \n for newlines, or use auth-public.pem / auth-private.pem locally (gitignored).
# AUTH_ISSUER_URL=https://joinvibo.com
# AUTH_PUBLIC_KEY=
# AUTH_PRIVATE_KEY=

# Convex → Settings → Environment Variables (server-side only; do NOT prefix with NEXT_PUBLIC_)
#
# -----------------------------------------------------------------------------
# VIBO MEDIA (dual-region S3 + CDN) — docs/MEDIA_ENV_CONTRACT.md
# -----------------------------------------------------------------------------
#
# ========= APP_ENV (CRITICAL — set on Convex) =========
# Default when unset: development (never infer production from NODE_ENV alone).
# APP_ENV=development
# APP_ENV=production
#
# ========= DEV — dual write (APP_ENV=development) =========
# S3_BUCKET_DEV=vibo-media-dev-eu-1
# S3_BUCKET_DEV_US=vibo-media-dev-us-1
# Optional: AWS_S3_REGION_DEV_EU=eu-west-1   AWS_S3_REGION_DEV_US=us-east-1
#
# ========= PROD — fixed backup buckets (APP_ENV=production) =========
# vibo-media-backup-eu (eu-west-1) + vibo-media-backup-us (us-east-1) — no S3_BUCKET_DEV*
#
# ========= CDN (Convex — hostname only; match env) =========
# Dev:  CLOUDFRONT_DOMAIN=dev-cdn.joinvibo.com
# Prod: CLOUDFRONT_DOMAIN=cdn.joinvibo.com
# (Alias: AWS_CLOUDFRONT_DOMAIN)
#
# Backwards compat tier hints if APP_ENV unset: VIBO_MEDIA_ENV, CONVEX_DEPLOYMENT=dev:*
#
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — Convex only, never NEXT_PUBLIC_
#
# Browser uploads hit S3 directly unless you use the upload proxy (see convex_app/MEDIA_S3_CORS.md).
# Default: localhost/127.0.0.1 use same-origin /api/media/s3-put (no S3 CORS needed for dev).
# NEXT_PUBLIC_S3_UPLOAD_USE_PROXY=true   # always proxy (e.g. preview URL without S3 CORS)
# NEXT_PUBLIC_S3_UPLOAD_USE_PROXY=false  # always direct PUT (requires S3 CORS for that origin)
#
# Resend: https://resend.com — create an API key and add the SAME variable name in Convex.
# Signup OTP (`/api/auth/signup/send-code` → Convex `auth.sendEmailOtp`) runs on Convex servers:
# set RESEND_API_KEY + RESEND_FROM_EMAIL (+ optional EMAIL_PROVIDER) in Convex Dashboard for this deployment.
# Values below in .env.local help local tooling only; they do NOT reach Convex unless you use `convex dev` env sync.
# RESEND_API_KEY=
# Optional "from" address. Until your domain is verified at https://resend.com/domains , Resend only
# delivers to your Resend account email; the app falls back to one admin email + skips user confirmation.
# Use your verified domain address so both the admin copy (joinvibo@gmail.com) and the submitter
# confirmation appear From: businesses@joinvibo.com (or similar).
# RESEND_FROM_EMAIL=Vibo Business <businesses@joinvibo.com>
#
# Signup email verification (Convex: `signupVerification.ts` — same RESEND_API_KEY as above)
# Optional separate From for no-reply signup codes (must be verified in Resend).
# RESEND_SIGNUP_FROM=Vibo <no-reply@yourdomain.com>
# 16+ random chars; used to hash 4-digit codes. Set in Convex Dashboard → Environment Variables.
# SIGNUP_OTP_PEPPER=

# Help Center AI — MUST be set in Convex (this file is NOT used by Convex actions).
# 1) Create a key at https://openrouter.ai/keys
# 2) Convex Dashboard → your deployment → Settings → Environment Variables
# 3) Add: OPENROUTER_API_KEY = sk-or-v1-... (exact name; no NEXT_PUBLIC_ prefix)
# 4) Save so Convex redeploys. Vercel / .env.local do NOT supply this; only Convex does.
# CLI (optional): npx convex env set OPENROUTER_API_KEY sk-or-v1-...
# Optional:
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://joinvibo.com
# OPENROUTER_APP_TITLE=Vibo Help Center
#
# Next.js only (blog/news auto-translate): set OPENROUTER_API_KEY on Vercel / .env.local as well.
# Optional model override for translate routes only (otherwise OPENROUTER_MODEL is used):
# OPENROUTER_TRANSLATE_MODEL=openai/gpt-4o-mini

# Vercel / CI — Convex → Settings → Deploy key (only for production deploys, not local dev)
# CONVEX_DEPLOY_KEY=

# Newsroom — free key from https://newsapi.org (optional; mock articles used if unset)
# NEWS_API_KEY=

# Create Post — Google Places Autocomplete (Next.js server only; never NEXT_PUBLIC_).
# Used by /api/places/autocomplete and /api/places/details. Enable Places API + billing in Google Cloud.
# GOOGLE_PLACES_API_KEY=

# Blog / Newsroom — auto Arabic when manual Arabic fields are empty in the CMS.
# When OPENROUTER_API_KEY is set on this Next.js app, /api/translate/* uses OpenRouter first (recommended on Vercel).
# If OpenRouter is unset, LibreTranslate is used when configured (self-hosted URL or public + API key).
# Remove LIBRETRANSLATE_* from Vercel if you rely only on OpenRouter.
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=

# Hero MP4s — pick ONE approach (leave all unset locally if files exist in public/videos/)
#
# A) Full URL per clip in Vercel (paste each “Copy link” from GitHub Release assets):
# NEXT_PUBLIC_VIDEO_VID1=https://github.com/vibobh/vibo-webapp/releases/download/media-v1/vid1.mp4
# NEXT_PUBLIC_VIDEO_VID2=
# NEXT_PUBLIC_VIDEO_VID3=
# NEXT_PUBLIC_VIDEO_VID4=
# NEXT_PUBLIC_VIDEO_VID5=
#
# B) Or one base folder (no trailing slash); filenames vid1.mp4…vid5.mp4 are appended:
# NEXT_PUBLIC_VIDEO_BASE_URL=https://github.com/vibobh/vibo-webapp/releases/download/media-v1

# Blog (Convex required for posts). Set the SAME BLOG_ADMIN_SECRET in Convex Dashboard → Settings → Environment Variables.
# BLOG_SESSION_SECRET — random string (e.g. openssl rand -hex 32) to sign admin cookies
# BLOG_ADMIN_SECRET — random string shared with Convex; never commit real values
# BLOG_ADMIN_EMAIL / BLOG_ADMIN_PASSWORD — sign-in for https://joinvibo.com/mangment
# Optional second editor: BLOG_ADMIN_EMAIL_2 + BLOG_ADMIN_PASSWORD_2 (same pattern up to _10)
# Or one JSON array (single line): BLOG_ADMIN_USERS=[{"email":"a@b.com","password":"..."},{"email":"c@d.com","password":"..."}]
# BLOG_SESSION_SECRET=
# BLOG_ADMIN_SECRET=
# BLOG_ADMIN_EMAIL=
# BLOG_ADMIN_PASSWORD=
# BLOG_ADMIN_EMAIL_2=
# BLOG_ADMIN_PASSWORD_2=
# BLOG_ADMIN_USERS=

# SEO / JSON-LD sameAs (optional). Set real profile URLs for production — used in schema.org Organization + SoftwareApplication.
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/...
# NEXT_PUBLIC_SOCIAL_X=https://x.com/...
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/...
# NEXT_PUBLIC_SOCIAL_TIKTOK=https://www.tiktok.com/@...
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/@...
